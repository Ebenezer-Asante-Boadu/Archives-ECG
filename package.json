{
  "name": "ecg-archives",
  "version": "1.0.0",
  "description": "LOCAL SERVER APP FOR MANAGING DATABASE SYSTEMS",
  "main": "./src/dist/server.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "serve": "cd ./front-end &&  npm run build && cd ../ && nodemon",
    "build": "cd ./front-end &&  npm run build && cd ../ && tsc && pkg . --force"
  },
  "author": "MENSAH TORKORNOO DERRICK",
  "license": "ISC",
  "devDependencies": {
    "@types/sqlite3": "^3.1.8",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.1.4",
    "express": "^4.18.2",
    "firebase-admin": "^11.9.0",
    "sqlite3": "^5.1.6",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "@types/express": "^4.17.17",
    "firebase": "^9.22.2"
  },
  "pkg": {
    "scripts": [
      "./src/dist/**/*.js",
      "./front-end/src/**/*.js"
    ],
    "assets": [
      "./src/dist/**/*",
      "./front-end/src/**/*"
    ],
    "outputPath": "DESKTOP-APPS",
    "targets": [
      "node18-win-x64",
      "node18-macos-x64",
      "node18-linux-x64"
    ]
  },
  "bin": {
    "myapp": "./src/dist/server.js"
  }
}
