{
  "name": "ecg-archives",
  "version": "1.0.0",
  "description": "LOCAL SERVER APP FOR MANAGING DATABASE SYSTEMS",
  "main": "./src/dist/server.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "serve": "cd ./front-end/archives-frontend &&  npm run build && cd ../../ && nodemon",
    "build": "cd ./front-end/archives-frontend &&  npm run build && cd ../../ && tsc && pkg . --force"
  },
  "author": "MENSAH TORKORNOO DERRICK",
  "license": "ISC",
  "devDependencies": {
    "@types/sqlite3": "^3.1.8",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.1.4",
    "express": "^4.18.2",
    "sqlite3": "^5.1.6",
    "typescript": "^5.1.3",
    "vite": "^4.3.9"
  },
  "dependencies": {
    "@types/express": "^4.17.17",
    "firebase": "^9.22.2",
    "firebase-admin": "^11.9.0"
  },
  "pkg": {
    "scripts": "./src/dist/**/*.js",
    "assets": "./src/dist/**/*",
    "outputPath": "DESKTOP-APPS",
    "targets": [
      "node14-win-x64",
      "node14-macos-x64",
      "node14-linux-x64"
    ]
  },
  "bin": {
    "myapp": "./src/dist/server.js"
  }
}
