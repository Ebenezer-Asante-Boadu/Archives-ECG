{
  "name": "ecg-archives",
  "version": "1.0.0",
  "description": "LOCAL SERVER APP FOR MANAGING DATABASE SYSTEMS",
  "main": "./src/dist/server.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "serve": "cross-env NODE_ENV=development  && cd ./front-end &&  npm run start && cd ../ && nodemon",
    "build": "cross-env NODE_ENV=production && cd ./front-end &&  npm run start && cd ../ && tsc && pkg . --force"
  },
  "author": "MENSAH TORKORNOO DERRICK",
  "license": "ISC",
  "devDependencies": {
    "@types/nodemailer": "^6.4.8",
    "@types/sqlite3": "^3.1.8",
    "cross-env": "^7.0.3",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.1.4",
    "express": "^4.18.2",
    "firebase-admin": "^11.9.0",
    "sqlite3": "^5.1.6",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "@google-cloud/storage": "^6.11.0",
    "@types/express": "^4.17.17",
    "nodemailer": "^6.9.3",
    "nodemon": "^2.0.22"
  },
  "pkg": {
    "scripts": [
      "./src/dist/**/*.js",
      "./front-end/dist/assets/javascript/**/*.js"
    ],
    "assets": [
      "./src/dist/**/*",
      "./front-end/dist/assets/resources/**/*",
      "./front-end/dist/assets/css/**/*"
    ],
    "outputPath": "DESKTOP-APPS",
    "targets": [
      "node18-win-x64",
      "node18-macos-x64",
      "node18-linux-x64"
    ]
  },
  "bin": {
    "myapp": "./src/dist/server.js"
  }
}
